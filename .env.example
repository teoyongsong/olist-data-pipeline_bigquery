# BigQuery pipeline - copy to .env and set values

# GCP project ID (required)
BQ_PROJECT=your-gcp-project-id

# BigQuery datasets (raw = CSV load target; dw = star schema)
BQ_DATASET_RAW=raw_olist
BQ_DATASET_STAGING=dw_stg_olist
BQ_DATASET_DW=dw_dw

# Path to Olist CSV files (from Kaggle: Brazilian E-Commerce Public Dataset by Olist)
DATA_DIR=./data/olist

# Optional: service account key path (if not using gcloud auth application-default login)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
